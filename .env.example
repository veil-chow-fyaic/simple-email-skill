# ============================================================
#  simple-email 凭据与配置模板
#  复制为 .env 后填入真实值,.env 不会入库。
#  获取授权码见 docs/foxmail-setup.md
# ============================================================

# --- 邮箱账号(完整地址) ---
EMAIL_USER=feng.463728559@foxmail.com

# --- 授权码(不是登录密码!) ---
# Foxmail / QQ 邮箱:在「设置→账户→IMAP/SMTP服务」开启后生成授权码
# 163:在「设置→POP3/SMTP/IMAP」开启后设置客户端授权密码
# Gmail:需开启两步验证后生成「应用专用密码」
EMAIL_PASS=your_authorization_code_here

# --- 协议预设(留空则按 EMAIL_USER 后缀自动匹配,见 scripts/lib/config.js) ---
# 可选值: foxmail | qq | 163 | 126 | gmail | outlook | sina | custom
EMAIL_PRESET=

# --- 自定义服务器(仅 EMAIL_PRESET=custom 时需要) ---
IMAP_HOST=
IMAP_PORT=993
SMTP_HOST=
SMTP_PORT=465

# --- 通用行为开关 ---
# IMAP 默认信箱(INBOX / Junk / Sent 等)
EMAIL_MAILBOX=INBOX
# 连接超时(毫秒)
EMAIL_TIMEOUT=30000
# 发件人显示名
EMAIL_FROM_NAME=
