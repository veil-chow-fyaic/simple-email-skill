{
  "name": "simple-email",
  "version": "0.1.0",
  "description": "通用 IMAP/SMTP email skill,任意 agent 可加载。支持收发邮件、查看未读、搜索、标记已读/未读、下载附件。兼容 Foxmail/QQ、163、Gmail 等所有标准 IMAP/SMTP 服务。",
  "type": "commonjs",
  "scripts": {
    "imap": "node scripts/imap.js",
    "smtp": "node scripts/smtp.js",
    "doctor": "node scripts/doctor.js",
    "classify": "node examples/classifier/classify.js",
    "workflow": "node examples/workflow/pipeline.js",
    "demo:classify": "node examples/classifier/classify.js --dry-run --in examples/classifier/fixture.json",
    "demo:workflow": "node examples/workflow/pipeline.js --in examples/classifier/fixture.json --out output/demo --format both",
    "test": "node --test \"test/**/*.test.js\""
  },
  "dependencies": {
    "imapflow": "^1.0.186",
    "mailparser": "^3.7.4",
    "nodemailer": "^7.0.5"
  },
  "optionalDependencies": {
    "exceljs": "^4.4.0"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "MIT"
}
